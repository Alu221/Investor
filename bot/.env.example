# Telegram Bot Token (от @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Claude Code OAuth token (подписка Max — основной)
CLAUDE_API_KEY=sk-ant-oat01-your_oauth_token_here

# Anthropic API key (fallback когда OAuth протух — платный, но не протухает)
ANTHROPIC_API_KEY=sk-ant-api03-your_api_key_here

# Claude Model (sonnet для баланса цена/качество)
CLAUDE_MODEL=sonnet

# ID админа для уведомлений о протухшем токене (Telegram user ID)
ADMIN_USER_ID=

# Whitelist пользователей (через запятую, пустой = доступен всем)
ALLOWED_USER_IDS=

# Rate limiting
RATE_LIMIT_MESSAGES=15
RATE_LIMIT_WINDOW=300
